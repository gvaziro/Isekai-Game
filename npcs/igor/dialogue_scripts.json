{
  "scenes": [
    {
      "id": "igor_first_craft_talk_to_igor",
      "questId": "igor_first_craft",
      "stageId": "talk_to_igor",
      "version": 1,
      "steps": [
        {
          "id": "start",
          "npcText": "Елена прислала? Отлично. У нас тут два варианта: смотреть на дерево с камнем или сделать из них вещь, которая не стыдно лежит в руке.",
          "choices": [
            {
              "label": "Покажи верстак.",
              "playerText": "Покажи верстак.",
              "nextStepId": "workbench",
              "unlockLoreFactIds": ["world.forest_resources"]
            }
          ]
        },
        {
          "id": "workbench",
          "npcText": "На верстаке собери базовый топорик. Рецепт простой: материалы есть, руки есть, остальное — не спорить с доской.",
          "choices": [
            {
              "label": "Сделаю топорик.",
              "playerText": "Сделаю топорик.",
              "complete": true
            }
          ]
        }
      ]
    },
    {
      "id": "igor_first_craft_report_to_igor",
      "questId": "igor_first_craft",
      "stageId": "report_to_igor",
      "version": 1,
      "steps": [
        {
          "id": "start",
          "npcText": "О, уже не просто куча припасов. Топорик годится: дерево уважает, пальцы пока на месте, значит работа принята.",
          "choices": [
            {
              "label": "Куда дальше?",
              "playerText": "Куда дальше?",
              "nextStepId": "send_to_marcus"
            }
          ]
        },
        {
          "id": "send_to_marcus",
          "npcText": "Теперь к Маркусу. Он любит, когда люди сначала проверяют ближайшую опасность, а потом уже строят из себя легенду.",
          "choices": [
            {
              "label": "Пойду к Маркусу.",
              "playerText": "Пойду к Маркусу.",
              "complete": true,
              "unlockLoreFactIds": ["world.dungeon_monsters"]
            }
          ]
        }
      ]
    },
    {
      "id": "igor_deep_supplies_report_supplies_to_igor",
      "questId": "igor_deep_supplies",
      "stageId": "report_supplies_to_igor",
      "version": 1,
      "steps": [
        {
          "id": "start",
          "npcText": "Железо, верёвка, и выражение лица человека, который уже понял цену лестницы вниз. Хороший набор. Почти профессиональный, если не смотреть слишком строго.",
          "choices": [
            {
              "label": "Этого хватит?",
              "playerText": "Этого хватит?",
              "nextStepId": "seal_hint",
              "unlockLoreFactIds": ["world.deep_supplies"]
            }
          ]
        },
        {
          "id": "seal_hint",
          "npcText": "До шестого этажа — должно. Ниже уже не снабжение решает, а то, насколько печать не любит гостей. Осколок Елене покажи, если найдёшь новый холодный след.",
          "choices": [
            {
              "label": "Понял. Иду глубже.",
              "playerText": "Понял. Иду глубже.",
              "complete": true,
              "unlockLoreFactIds": ["world.seal_nodes"]
            }
          ]
        }
      ]
    }
  ]
}
