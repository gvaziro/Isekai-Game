# Скопируйте в .env.local и заполните.

OPENAI_API_KEY=sk-...

# Модель для реплик NPC (по умолчанию в коде gpt-5.4-mini; подставьте id из аккаунта OpenAI).
NPC_MODEL=gpt-5.4-mini

# Опционально: отдельная модель для summarize_dialogue в /api/npc/[npcId]/event.
# NPC_SUMMARY_MODEL=gpt-5.4-mini

# Модель embeddings для векторного поиска по базе знаний.
EMBEDDING_MODEL=text-embedding-3-small

# Опционально: путь к локальному JSON-индексу embeddings.
# KNOWLEDGE_VECTOR_INDEX_PATH=knowledge-vector-index.json

# Опционально: размер батча при генерации embeddings.
# EMBEDDING_BATCH_SIZE=64

# Опционально: логировать причины fallback vector search в NPC runtime.
# KNOWLEDGE_VECTOR_LOG=1

# Debug: log token usage for every NPC AI reply in the dev server.
# Enabled by default in development; set 0 to silence, or 1 to force-enable in production.
# NPC_LOG_TOKEN_USAGE=1
